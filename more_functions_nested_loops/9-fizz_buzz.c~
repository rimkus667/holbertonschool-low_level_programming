#include <stdio.h>
/**
 * print_diagonal - diagonal line
 * @n - nombre de slash
 * Return: 
 */
int main(void)
{
int num;
for (num = 1; num <= 100; num++)
{
if (num % 3 == 0)
{
printf("Fizz\n");
}
if (num % 5 == 0)
{
printf("Buzz\n");
}
if (num % 3 == 0 && num % 5 == 0)
{
printf("FizzBuzz\n");
}
else
{
printf("%d\n", num);
}
}
return 0;
}
